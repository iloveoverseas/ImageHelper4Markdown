<Window x:Class="ImageHelper4Markdown.ImageSaveInfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        AllowsTransparency="True"
        Background="#A0000000"
        Title="画像保存情報" Height="180" Width="500" ResizeMode="NoResize" WindowStyle="None" Loaded="Window_Loaded">
    <!--50% 透過は 80（16進数で 128）-->

    <Window.Resources>
        <Style x:Key="ButtonDefault" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Background" Value="DarkGray"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="WhiteSmoke" BorderThickness="0" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="LightGray"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="DarkGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <StackPanel Margin="16">
        <TextBlock Text="保存する画像の名称を入力してください。" Foreground="White" FontSize="20"/>
        <TextBox x:Name="DescriptionBox" VerticalAlignment="Center" materialDesign:HintAssist.Hint="ファイル名を入力" Background="White" Foreground="Black" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Width="420" Margin="0,10,0,0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Style="{StaticResource ButtonDefault}" Content="保存" Foreground="White" Width="60" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Style="{StaticResource ButtonDefault}" Content="取消" Foreground="White" Width="60" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
        <TextBlock x:Name="Message" Text="" Background="Transparent" Foreground="White" Margin="0,10,0,0"/>
    </StackPanel>
</Window>