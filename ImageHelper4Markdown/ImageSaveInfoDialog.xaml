<Window x:Class="ImageHelper4Markdown.ImageSaveInfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画像保存情報" Height="220" Width="350" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None">
    <StackPanel Margin="16">
        <TextBlock Text="説明:"/>
        <TextBox x:Name="DescriptionBox" Margin="0,4,0,8"/>
        <TextBlock Text="ファイル名:"/>
        <TextBox x:Name="FileNameBox" Margin="0,4,0,8"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="60" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="キャンセル" Width="60" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>